{
  "entities": {
    "Product": {
      "title": "Diamond Product",
      "description": "A luxury diamond product in the catalog.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "price": { "type": "number" },
        "carat": { "type": "number" },
        "cut": { "type": "string" },
        "clarity": { "type": "string" },
        "color": { "type": "string" },
        "shape": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "certificationUrl": { "type": "string" },
        "certNumber": { "type": "string" },
        "certLab": { "type": "string" },
        "inStock": { "type": "boolean" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "slug", "price", "carat", "cut", "clarity", "color", "shape", "images"]
    },
    "User": {
      "title": "User Profile",
      "description": "Stored user profile data.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["CUSTOMER", "ADMIN"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "name", "role"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "CONFIRMED", "PROCESSING", "SHIPPED", "DELIVERED", "CANCELLED"] },
        "totalPrice": { "type": "number" },
        "shippingAddress": { "type": "object" },
        "trackingNumber": { "type": "string" },
        "courier": { "type": "string" },
        "paystackRef": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "phone", "status", "totalPrice", "shippingAddress"]
    },
    "OrderItem": {
      "title": "Order Item",
      "description": "An item within an order.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "quantity": { "type": "number" }
      },
      "required": ["productId", "name", "price", "quantity"]
    },
    "OrderUpdate": {
      "title": "Order Update",
      "description": "A tracking timeline entry.",
      "type": "object",
      "properties": {
        "status": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["status", "createdAt"]
    },
    "CartItem": {
      "title": "Cart Item",
      "description": "An item in a user's cart.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "quantity": { "type": "number" }
      },
      "required": ["productId", "quantity"]
    }
  },
  "firestore": {
    "products": { "schema": "Product", "description": "Collection of diamonds" },
    "users": { "schema": "User", "description": "User profiles" },
    "users/{userId}/cart": { "schema": "CartItem", "description": "User cart items" },
    "orders": { "schema": "Order", "description": "Customer orders" },
    "orders/{orderId}/items": { "schema": "OrderItem", "description": "Items in an order" },
    "orders/{orderId}/updates": { "schema": "OrderUpdate", "description": "Tracking timeline updates" }
  }
}
